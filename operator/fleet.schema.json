{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specdog.github.io/leash/operator/fleet.schema.json",
  "title": "Leash private fleet configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["robots"],
  "properties": {
    "fleetName": { "type": "string", "minLength": 1 },
    "pollMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
    "snapshotMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
    "robots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/robot" }
    }
  },
  "$defs": {
    "robot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "baseUrl"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "baseUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://[^/?#]+/?$"
        },
        "location": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "videoTransport": {
          "type": "string",
          "enum": ["auto", "mjpeg", "webrtc"]
        }
      }
    }
  }
}
