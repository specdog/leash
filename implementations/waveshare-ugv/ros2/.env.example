# Copy to a private file outside the repository. Do not commit measured values.
LEASH_ROS_LOCALIZATION_TOKEN_FILE=/home/operator/.config/leash/localization-token
LEASH_ROS_MAP_STATE_DIR=/home/operator/.local/state/leash/waveshare-ugv-slam

# Provisional values may be used only for stationary read-only bring-up. Issue
# #166 replaces them with measured, versioned calibration.
LEASH_ROS_WHEEL_TRACK_M=0.20
LEASH_ROS_WHEEL_SCALE=1.0
LEASH_ROS_SCAN_X_M=0.0
LEASH_ROS_SCAN_Y_M=0.0
LEASH_ROS_SCAN_Z_M=0.10
LEASH_ROS_SCAN_YAW_RAD=0.0
LEASH_ROS_CAMERA_X_M=0.0
LEASH_ROS_CAMERA_Y_M=0.0
LEASH_ROS_CAMERA_Z_M=0.15
LEASH_ROS_CAMERA_YAW_RAD=0.0

ROS_DOMAIN_ID=42
